// Dropdown submenu styles
.menu-item-has-children {
  position: relative;

  > a::after {
    content: '\f107';
    font-family: 'Font Awesome 6 Free';
    font-weight: 900;
    margin-left: 4px;
    font-size: 0.8em;
  }
}

.sub-menu {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 160px;
  background: var(--content-bg-color, #fff);
  border-radius: 5px;
  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.15);
  padding: 8px 0;
  z-index: 1050;
  list-style: none;
  margin: 0;

  .menu-item {
    display: block;
    margin: 0;

    a {
      display: block;
      padding: 6px 20px;
      color: var(--text-color, #555);
      font-size: 0.9em;
      border-bottom: none;
      white-space: nowrap;

      &:hover {
        background: var(--menu-item-bg-color, #f5f5f5);
        color: var(--link-hover-color, #222);
      }
    }
  }
}

.menu-item-has-children:hover > .sub-menu {
  display: block;
}
